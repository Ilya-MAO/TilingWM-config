#
# wm independent hotkeys
#

# terminal emulator
alt + t
	alacritty

# program launcher
super + @space
	rofi -show drun

super + alt + @space
	rofi -show run

# make sxhkd reload its configuration files:

super + {F9,F10,F11}
	playerctl {previous,play-pause,next}

super + F12
	amixer set Master toggle


super + alt + m
	amixer set Master 2%+

super + alt + shift + m
	amixer set Master 2%-


super + alt + shift + b
	brightnessctl set 1%-

super + alt + b
	brightnessctl set +1%


alt + shift + l
	$HOME/.config/polybar/scripts/language.sh

super + shift + w
	$HOME/.config/polybar/scripts/warp.sh -t

super + shift + s
	flameshot gui

#
# rofi scripts
#
#

super + F2
	$HOME/.config/rofi/scripts/power_menu.sh

super + F3
	$HOME/.config/rofi/scripts/bluetooth_menu.sh

super + F4
	$HOME/.config/rofi/scripts/color_theme.sh

super + F5
	$HOME/.config/rofi/scripts/timer.sh

#
# bspwm hotkeys
#

# quit/restart bspwm
ctrl + alt + q
	bspc {quit,wm -r}

# restart polybar
ctrl + alt + p
	polybar-msg cmd restart

# close and kill
alt + w
	bspc node -{c,k}

# swap the current node and the biggest window
super + g
	bspc node -s biggest.window

#
# state/flags
#

# set the window state
super + {t,shift + t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

#
# focus/swap
#

# focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus the all nodes on the desktop
super + p
	bspc node -f @parent

# focus the last node/desktop
super + {grave,Tab}
	bspc {node,desktop} -f last

# focus or send to the given desktop
super + {_,shift + }{1-4}
	bspc {desktop -f,node -d} '^{1-4}'

# focux alt desktop
super + alt + {_,shift + }{1,2,3,4}
	bspc {desktop -f,node -d} '^{5,6,7,8}'

#
# preselect
#

# preselect the direction
# super + ctrl + {h,j,k,l}
# 	bspc node -p {west,south,north,east}

# preselect the ratio
# super + ctrl + {1-9}
# 	bspc node -o 0.{1-9}

# cancel the preselection for the focused node
# super + ctrl + space
# 	bspc node -p cancel

# cancel the preselection for the focused desktop
# super + ctrl + shift + space
# 	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

#
# move/resize
#

# expand a window by moving one of its side outward
super + alt + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward
super + alt + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}
